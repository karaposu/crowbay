# filepath: .env.example
# Copy to .env and fill in. The app refuses to start without SECRET_KEY.

# Generate with: openssl rand -hex 32
SECRET_KEY=

# Bot <-> API trust bridge secret (required to enable POST /auth/telegram).
# Generate with: openssl rand -hex 32
BOT_BRIDGE_SECRET=

# Telegram bot (from @BotFather). Required only to run the bot process.
BOT_TOKEN=

# Defaults shown; uncomment to override.
# API_BASE_URL=http://localhost:8000
# TG_FILE_LIMIT_MB=20

# Email delivery: "console" logs instead of sending; "smtp" sends for real.
# EMAIL_BACKEND=console
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# EMAIL_FROM=
# PUBLIC_BASE_URL=http://localhost:8000

# SMS: "mock" is a Twilio-shaped fake (logs the code); "twilio" sends for real.
# SMS_BACKEND=mock
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
# DATABASE_URL=sqlite:////absolute/path/to/crowdjump.db
# ACCESS_TOKEN_MINUTES=30
# REFRESH_TOKEN_DAYS=14
# EMAIL_TOKEN_HOURS=48
# ENV=dev
# LOG_LEVEL=INFO
